# EUDI Wallet Tracker — Neon connection string (primary DB for this project).
# Strip `channel_binding=require` from the connection string (Drizzle gotcha, see STACK.md).
DATABASE_URL=

# Allekirjoitus Competitive Intel Tracker — Neon connection string.
# Used by the federated admin connection router to query the Allekirjoitus project's DB.
# See CLAUDE.md §3 "Per-project keys, MANDATORY" — this is a separate Neon instance from DATABASE_URL above.
# Strip `channel_binding=require` from the connection string (Drizzle gotcha, see STACK.md).
DATABASE_URL_ALLEKIRJOITUS=

# Anthropic API key for Claude calls.
ANTHROPIC_API_KEY=

# Admin UI password.
ADMIN_PASSWORD=

# Brevo (transactional email) API key + sender address.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# Shared secret required by Vercel cron routes (header `Authorization: Bearer <CRON_SECRET>`).
CRON_SECRET=
